# =============================================================================
# Sound Downloader — .gitignore
# =============================================================================
# 정책 요약:
#   - templates/ 가 마스터 소스. ROOT 의 app/, run.bat 은 regen 으로 생성되는
#     사본이므로 git 에 올리지 않는다.
#   - python/ (임베디드 Python), packages/ (pip 설치물) 는 setup.bat 으로 만들어진다.
#   - bin/ 의 외부 바이너리(yt-dlp, ffmpeg, ffprobe) 는 용량/라이선스/업데이트
#     이슈로 git 에 올리지 않는다. README.txt 만 추적.
#   - config.json 은 개인 API key 가 들어가므로 ignore. config.example.json 만 추적.
#   - 다운로드 결과물은 모두 ignore.
# =============================================================================


# -----------------------------------------------------------------------------
# 1) regen 으로 자동 생성되는 ROOT 사본
#    (편집은 templates/ 에서만!)
# -----------------------------------------------------------------------------
/app/
/run.bat


# -----------------------------------------------------------------------------
# 2) 임베디드 Python 런타임 (setup.bat 로 사용자가 받음)
# -----------------------------------------------------------------------------
/python/


# -----------------------------------------------------------------------------
# 3) pip 으로 설치되는 third-party 패키지 (setup.bat 가 만듦)
# -----------------------------------------------------------------------------
/packages/


# -----------------------------------------------------------------------------
# 4) 외부 바이너리 (배포 zip 에는 포함하지만 git 에는 X)
#    bin/README.txt 는 안내 문서이므로 추적 (! 로 예외 처리)
# -----------------------------------------------------------------------------
/bin/*
!/bin/README.txt


# -----------------------------------------------------------------------------
# 5) 다운로드 결과물 / 사용자 데이터
# -----------------------------------------------------------------------------
/downloads/
/youtube_links.csv
/links.csv
/youtube_log.csv


# -----------------------------------------------------------------------------
# 6) 개인 설정 (API key 포함)
#    → config.example.json 만 git 에 올리고, 실제 config.json 은 무시
# -----------------------------------------------------------------------------
/config.json


# -----------------------------------------------------------------------------
# 7) Python 캐시 / 빌드 부산물
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
*.bak
*.tmp
*.swp
*.orig


# -----------------------------------------------------------------------------
# 8) 에디터 / IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.iml
*.sublime-project
*.sublime-workspace
.cursor/


# -----------------------------------------------------------------------------
# 9) OS 부산물
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
.AppleDouble
.LSOverride


# -----------------------------------------------------------------------------
# 10) 환경 / 시크릿
# -----------------------------------------------------------------------------
.env
.env.local
*.key
*.secret


# -----------------------------------------------------------------------------
# 11) 잡다 (로그, 임시 노트 등)
# -----------------------------------------------------------------------------
*.log
새 텍스트 문서.txt
_test_*.csv
